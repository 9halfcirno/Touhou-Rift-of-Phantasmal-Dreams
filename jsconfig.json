{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ES2024",
        "jsx": "react-jsx",
        "allowImportingTsExtensions": true,
        "checkJs": false,
        "experimentalDecorators": false,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strict": true
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ],
    "paths": {
        "three": [
            "./libs/three-0.171.0/build/three.module.js"
        ],
        "three/addons/*": [
            "./libs/three-0.171.0/examples/jsm/*"
        ],
        "pixi": [
            "./libs/pixi/dist/pixi.mjs"
        ]
    }
}